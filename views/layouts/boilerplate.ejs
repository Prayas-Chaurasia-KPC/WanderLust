<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wanderlust</title>
    <link rel="icon" type="image/png" href="/images/compass-solid.svg" />
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" integrity="sha512-Kc323vGBEqzTmouAECnVceyQqyqdsSiqLQISBL29aUW4U/M7pSPA/gEUZQqv1cwx4OnYxTxve5UMg5GT6L4JJg==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/rating.css">
    <link rel="stylesheet" href="/css/show_ejs.css">
</head>
<body>
    <%- include("../includes/navbar.ejs") %>
    <div class="container">
        <%- include("../includes/flash.ejs") %>
        <%- body %>
    </div>
    <%- include("../includes/footer.ejs") %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    <script src="/js/script.js"></script>
    <script>
        const searchForm = document.querySelector('.search-Form');
        const inp = document.querySelector('.search-bar');

        // Guard: these elements only exist on the index/listings page
        if (searchForm && inp) {
            const showListings        = document.querySelectorAll('.list-title');
            const showListingLocation = document.querySelectorAll('.list-location');
            const showListingCountry  = document.querySelectorAll('.list-country');
            const listingCols         = document.querySelectorAll('.listing-col'); // ← col wrapper, not .card
            const filterBtns          = document.querySelectorAll('.filter');

            // ── Helper: hide/show the COL wrapper (not the inner card) ──
            // This is the core fix — hiding .card left an empty column slot in the grid.
            // Hiding .listing-col removes it from the flex flow entirely → no ghost gaps.
            function showCol(col)  { col.classList.remove('hidden-col'); }
            function hideCol(col)  { col.classList.add('hidden-col'); }

            // ── Category filter ──────────────────────────────────────────
            filterBtns.forEach(btn => {
                btn.addEventListener('click', () => {
                    // Mark active filter
                    filterBtns.forEach(b => {
                        b.classList.remove('active-filter');
                        b.style.color  = '';
                        b.style.opacity = '';
                    });
                    btn.classList.add('active-filter');
                    btn.style.color   = 'red';
                    btn.style.opacity = '1';

                    const selected = btn.dataset.filter; // set via data-filter on each .filter div

                    listingCols.forEach(col => {
                        if (selected === 'all' || col.dataset.category === selected) {
                            showCol(col);
                        } else {
                            hideCol(col);
                        }
                    });

                    // Clear search input when a filter is clicked
                    inp.value = '';
                });
            });

            // ── Search ───────────────────────────────────────────────────
            searchForm.addEventListener('submit', function(event) {
                event.preventDefault();
                const searchResult = inp.value.toLowerCase().trim();

                // Reset all filter highlights when searching
                filterBtns.forEach(b => {
                    b.classList.remove('active-filter');
                    b.style.color   = '';
                    b.style.opacity = '';
                });

                // Show/hide the COL wrapper based on title, location, or country match
                showListings.forEach((item, index) => {
                    const title    = item.textContent.toLowerCase();
                    const location = showListingLocation[index]?.textContent.toLowerCase() || '';
                    const country  = showListingCountry[index]?.textContent.toLowerCase()  || '';
                    const col      = listingCols[index]; // ← target the col, not the card

                    if (title.includes(searchResult) || location.includes(searchResult) || country.includes(searchResult)) {
                        showCol(col);
                    } else {
                        hideCol(col);
                    }
                });
            });
        }
    </script>
</body>
</html>
